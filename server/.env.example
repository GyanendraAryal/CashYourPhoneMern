NODE_ENV=development
PORT=4000

# MongoDB connection string (use MongoDB Atlas in production)
MONGO_URI=

# JWT signing secret (rotate for production)
JWT_SECRET=

# Phase 0: split JWT secrets (recommended for production)
JWT_ACCESS_SECRET=dev_access_9f2c1a6b4e8d7c3a9f0b2e4d6c8a1f2
JWT_REFRESH_SECRET=dev_refresh_4a8c2f7d9e1b3c6a0d5f8e2b7c9a1d
ADMIN_JWT_SECRET=dev_admin_3c8e1a9f4d2b6c0e7f5a8d1c9b2e4


# Comma-separated list of allowed origins in production (fail-closed)
# Example:
# CORS_ORIGINS=https://cashyourphone.com,https://admin.cashyourphone.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Upload mode:
# - local: saves files to /uploads (dev fallback only)
# - cloudinary: uploads to Cloudinary (required for production)
UPLOAD_MODE=local

# Local upload settings (dev only)
LOCAL_UPLOAD_ROOT=uploads

# Cloudinary settings (required when UPLOAD_MODE=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix in Cloudinary
CLOUDINARY_FOLDER=cashyourphone

# Seeding (manual / controlled)
RUN_SEED=false
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
# Strong limit for admin login
ADMIN_LOGIN_RATE_LIMIT_MAX=10

# Client app URL (used for redirect after payment callbacks)
CLIENT_APP_URL=http://localhost:5173

# ==============================
# eSewa ePay v2 (Payment Gateway)
# ==============================
# Production (NODE_ENV=production): ESEWA_SECRET_KEY, SERVER_PUBLIC_URL, and
# CLIENT_APP_URL or FRONTEND_URL are required at startup.
# Test/UAT Credentials
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=your_esewa_test_secret_here
ESEWA_FORM_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_BASE_URL=https://uat.esewa.com.np/api/epay/transaction/status/

# Production Credentials (Uncomment and set correctly)
# ESEWA_PRODUCT_CODE=YOUR_PRODUCTION_PRODUCT_CODE
# ESEWA_SECRET_KEY=YOUR_PRODUCTION_SECRET_KEY
# ESEWA_FORM_URL=https://epay.esewa.com.np/api/epay/main/v2/form
# ESEWA_STATUS_BASE_URL=https://epay.esewa.com.np/api/epay/transaction/status/

# Public base URL of your backend (recommended for production)
# Example: https://api.cashyourphone.com
SERVER_PUBLIC_URL=http://localhost:4000

# Optional: error monitoring (https://sentry.io)
# SENTRY_DSN=
